{
    "chat.tools.terminal.autoApprove": {
        "./gradlew": true,
        "/^bash \\./gradlew assembleDebug$/": {
            "approve": true,
            "matchCommandLine": true
        }
    },
    "java.jdt.ls.java.home": "${env:JAVA_HOME:/opt/homebrew/opt/openjdk@21}",
    "java.configuration.runtimes": [
        {
            "name": "JavaSE-21",
            "path": "${env:JAVA_HOME:/opt/homebrew/opt/openjdk@21}",
            "default": true
        }
    ],
    "_comment": "java.jdt.ls.java.home: Set to your Java 21 installation. Common paths: /opt/homebrew/opt/openjdk@21 (macOS ARM), /usr/local/opt/openjdk@21 (macOS Intel), /usr/lib/jvm/java-21 (Linux), $HOME/.sdkman/candidates/java/21.current (SDKMAN)",
    "java.configuration.updateBuildConfiguration": "interactive",
    "redhat.telemetry.enabled": false
}