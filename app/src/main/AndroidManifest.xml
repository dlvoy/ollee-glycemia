<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="pl.cukrzycowy.ollee.glycemia">

<!-- Permissions -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT"/>
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"/>
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"/>

    <application
        android:allowBackup="true"
        android:label="Ollee Glycemia"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:localeConfig="@xml/locales_config"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar">

        <activity
            android:name="pl.cukrzycowy.ollee.glycemia.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.App.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <receiver
            android:name="pl.cukrzycowy.ollee.glycemia.XdripReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.eveningoutpost.dexdrip.BgEstimate"/>
                <action android:name="com.eveningoutpost.dexdrip.BROADCAST"/>
                <action android:name="org.nightscout.android.broadcast"/>
                <action android:name="com.eveningoutpost.dexdrip.ExternalStatusChange"/>
            </intent-filter>
        </receiver>

        <receiver
            android:name="pl.cukrzycowy.ollee.glycemia.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
            </intent-filter>
        </receiver>

        <service
            android:name="pl.cukrzycowy.ollee.glycemia.BleService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice|dataSync"/>

    </application>
</manifest>